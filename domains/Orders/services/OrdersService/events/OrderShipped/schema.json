{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "io.eventcatalog.orders.event.order-shipped",
  "title": "OrderShipped",
  "description": "Published when an order has been dispatched to the customer.",
  "type": "object",
  "properties": {
    "orderId": {
      "type": "string",
      "format": "uuid",
      "description": "Identifier of the order that was shipped."
    },
    "userId": {
      "type": "string",
      "format": "uuid",
      "description": "Identifier of the customer who placed the order."
    },
    "orderItems": {
      "type": "array",
      "description": "The items included in the shipment.",
      "items": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "description": "Identifier of the shipped product."
          },
          "productName": {
            "type": "string",
            "description": "Human-friendly name of the shipped product."
          },
          "quantity": {
            "type": "number",
            "description": "Quantity of the product in this shipment."
          }
        },
        "required": [
          "productId",
          "quantity"
        ],
        "additionalProperties": true
      }
    },
    "orderStatus": {
      "type": "string",
      "enum": [
        "shipped"
      ]
    },
    "carrier": {
      "type": "string",
      "description": "Shipping carrier handling the delivery.",
      "examples": [
        "dhl",
        "ups"
      ]
    },
    "trackingNumber": {
      "type": "string",
      "description": "Carrier tracking number for the shipment."
    },
    "estimatedDelivery": {
      "type": "string",
      "format": "date-time",
      "description": "Estimated delivery time, if known."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 time the order was shipped."
    }
  },
  "required": [
    "orderId",
    "userId",
    "orderStatus",
    "carrier",
    "trackingNumber",
    "timestamp"
  ],
  "additionalProperties": false
}
