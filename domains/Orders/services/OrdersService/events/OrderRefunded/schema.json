{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrderRefunded",
  "type": "object",
  "properties": {
    "orderId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the order."
    },
    "userId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the user."
    },
    "orderStatus": {
      "type": "string",
      "enum": ["refunded"],
      "description": "The status of the order after refund."
    },
    "totalAmount": {
      "type": "number",
      "description": "Full amount of the order before refund."
    },
    "refundAmount": {
      "type": "number",
      "description": "Amount refunded to the customer."
    },
    "refundReason": {
      "type": "string",
      "description": "Reason for the issued refund."
    },
    "refundedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the refund was processed."
    }
  },
  "required": [
    "orderId",
    "userId",
    "orderStatus",
    "totalAmount",
    "refundAmount",
    "refundReason",
    "refundedAt"
  ]
}
